{
  "manifest_version": 3,
  "name": "MLX Studio Page Assist",
  "version": "0.5.0",
  "description": "Send page selections from Chromium into the local MLX Studio inbox.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8899/*",
    "http://localhost:8899/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open MLX Studio Side Panel"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
